{
  "name": "deca",
  "private": true,
  "packageManager": "bun@1.1.34",
  "scripts": {
    "dev": "bun --filter '@deca/gateway' serve",
    "gateway": "bun --filter '@deca/gateway' serve",
    "test": "bun run test:unit",
    "test:unit": "bun --filter '@deca/*' test:unit",
    "test:e2e": "bun --filter '@deca/*' test:e2e",
    "test:all": "bun run test:unit && bun run test:e2e",
    "test:coverage": "bun --filter '@deca/*' test --coverage",
    "lint": "bun --filter '@deca/*' lint",
    "format": "biome format .",
    "prepare": "husky",
    "eval": "bun run eval/runner.ts",
    "eval:report": "bun run eval/reporter.ts"
  },
  "workspaces": ["packages/*"],
  "overrides": {
    "ws": "^8.20.1",
    "vite": "^8.0.16",
    "@babel/core": "^7.29.6",
    "undici": "^6.27.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/node": "^26.1.0",
    "@vitest/coverage-istanbul": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "husky": "^9.1.7",
    "vitest": "^4.1.9"
  }
}
